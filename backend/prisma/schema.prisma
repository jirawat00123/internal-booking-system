generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // เพิ่มบรรทัดนี้ เพื่อใช้ตอน Migrate
}

model Department {
  id             Int        @id @default(autoincrement())
  departmentCode String?    @map("department_code") // 👈 เติม ? ตรงนี้ครับ สำคัญมาก!
  departmentName String     @map("department_name")
  employee       Employee[]
  positions      Position[]

  @@map("departments")
}

model Position {
  id           Int    @id @default(autoincrement())
  positionName String @map("position_name")

  // 1. ช่องเก็บเลข ID ของแผนก (จัดเก็บลงฐานข้อมูลจริง)
  departmentId Int @map("department_id")

  // 2. ตัวเชื่อมความสัมพันธ์เสมือน เพื่อให้ Prisma ทำงานร่วมกับตาราง Department ได้
  department Department @relation(fields: [departmentId], references: [id])

  employees Employee[]

  @@index([departmentId]) // ทำหน้าที่ช่วยให้ค้นหาตำแหน่งตามแผนกได้เร็วขึ้น
  @@map("positions")
}

model Employee {
  id           Int        @id @default(autoincrement())
  employeeCode String     @unique @map("employee_code")
  fullName     String     @map("full_name")
  positionId   Int        @map("position_id")
  departmentId Int        @map("departments_id")
  isActive     Boolean    @default(true) @map("is_active") // 👈 เพิ่มบรรทัดนี้เข้าไปครับ
  department   Department @relation(fields: [departmentId], references: [id])
  position     Position   @relation(fields: [positionId], references: [id])
  users        User[]

  @@index([positionId])
  @@map("employees")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String
  users User[]

  @@map("roles")
}

model User {
  id                      Int                     @id @default(autoincrement())
  employeeId              Int                     @map("employee_id")
  roleId                  Int                     @map("role_id")
  pin                     String?                 @map("pin_hash") 
  pinInitialized          Boolean                 @default(false) @map("pin_initialized")   
  pinChangedAt            DateTime?               @map("pin_changed_at")                   
  pinResetRequired        Boolean                 @default(false) @map("pin_reset_required") 
  active                  Boolean                 @default(true)
  currentSessionId        String?                 @map("current_session_id") 
  createdAt               DateTime                @default(now()) @map("created_at")
  attachments             Attachment[]
  auditLogs               AuditLog[]
  roomBookingHistories    RoomBookingHistory[]    @relation("RoomHistoryByUser")
  roomBookings            RoomBooking[]
  employee                Employee                @relation(fields: [employeeId], references: [id])
  role                    Role                    @relation(fields: [roleId], references: [id])
  vehicleBookingHistories VehicleBookingHistory[] @relation("VehicleHistoryByUser")
  vehicleBookings         VehicleBooking[]        @relation("BookingUser")
  vehicleLogsCheckOut     VehicleLog[]            @relation("CheckoutByUser")
  vehicleLogsReturn       VehicleLog[]            @relation("ReturnByUser")

  @@index([employeeId])
  @@index([roleId])
  @@map("users")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String
  module    String
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

model Room {
  id        Int        @id @default(autoincrement())
  roomName  String     @map("room_name")
  location  String
  capacity  Int
  status    RoomStatus @default(AVAILABLE)
  uploadUrl String?    @map("upload_url")

  isDeleted Boolean @default(false) @map("is_deleted")

  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  bookings  RoomBooking[]

  @@map("rooms")
}

model RoomBooking {
  id            Int                  @id @default(autoincrement())
  userId        Int                  @map("user_id")
  roomId        Int                  @map("room_id")
  purpose       String
  // เปลี่ยนจาก String เป็น Enum
  status        BookingStatus        @default(PENDING)
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")
  endDatetime   DateTime             @map("end_datetime")
  startDatetime DateTime             @map("start_datetime")
  attachments   Attachment[]
  histories     RoomBookingHistory[]
  room          Room                 @relation(fields: [roomId], references: [id], onDelete: Restrict)
  user          User                 @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([roomId])
  // เพิ่ม Index สำหรับค้นหาช่วงเวลา
  @@index([startDatetime, endDatetime])
  @@map("room_bookings")
}

model Vehicle {
  id          Int              @id @default(autoincrement())
  plateNumber String           @unique @map("license_plate")
  province    String?          @map("province")
  brand       String
  model       String
  seats       Int              @default(4)
  status      VehicleStatus    @default(AVAILABLE)
  uploadUrl   String?          @map("upload_url")
  isDeleted   Boolean          @default(false) @map("is_deleted")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @default(now()) @updatedAt @map("updated_at")
  vehicleName String           @map("vehicle_name")
  bookings    VehicleBooking[]

  @@map("vehicles")
}

model VehicleBooking {
  id            Int                     @id @default(autoincrement())
  vehicleId     Int                     @map("vehicle_id")
  userId        Int                     @map("user_id")
  destination   String
  startDatetime DateTime                @map("start_datetime")
  endDatetime   DateTime                @map("end_datetime")
  purpose       String
  status        String                  @default("Pending")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  passengers    Int                     @default(1) @map("passengers")
  attachments   Attachment[]
  histories     VehicleBookingHistory[]
  // 💡 2. เพิ่มชื่อ Relation (เช่น "BookingUser") เพื่อป้องกัน Prisma สับสน กรณีที่มี FK ชี้ไปที่ตาราง User 2 ตัว
  user          User                    @relation("BookingUser", fields: [userId], references: [id])
  vehicle       Vehicle                 @relation(fields: [vehicleId], references: [id])
  vehicleLogs   VehicleLog[]

  @@index([vehicleId])
  @@index([userId])
  @@map("vehicle_bookings") // 💡 เพิ่มบรรทัดนี้ เพื่อบอกให้ Prisma รู้จักชื่อตารางจริงใน pgAdmin
}

model VehicleLog {
  id                Int            @id @default(autoincrement())
  vehicleBookingId  Int            @map("vehicle_booking_id")
  checkoutById      Int            @map("checkout_by")
  checkoutTime      DateTime       @map("checkout_time")
  checkoutMileage   Int            @map("checkout_mileage")
  checkoutFuelLevel Int            @map("checkout_fuel_level")
  returnById        Int?           @map("return_by")
  returnTime        DateTime?      @map("return_time")
  returnMileage     Int?           @map("return_mileage")
  returnFuelLevel   Int?           @map("return_fuel_level")
  returnMileagePhoto String?       @map("return_mileage_photo")   // รูปเลขไมล์หลังใช้งาน
  returnFrontPhoto   String?       @map("return_front_photo")     // รูปหน้ารถหลังใช้งาน
  returnBackPhoto    String?       @map("return_back_photo")      // รูปหลังรถหลังใช้งาน
  remark            String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  checkoutBy        User           @relation("CheckoutByUser", fields: [checkoutById], references: [id])
  returnBy          User?          @relation("ReturnByUser", fields: [returnById], references: [id])
  booking           VehicleBooking @relation(fields: [vehicleBookingId], references: [id])

  @@index([vehicleBookingId])
  @@index([checkoutById])
  @@index([returnById])
  @@map("vehicle_logs")
}

model Attachment {
  id               Int             @id @default(autoincrement())
  entityType       String          @map("entity_type")
  entityId         Int             @map("entity_id")
  fileName         String          @map("file_name")
  // ✅ 1. เพิ่ม @unique เพื่อป้องกันไฟล์ผี/การบันทึก UUID ซ้ำซ้อนลงฐานข้อมูล
  filePath         String          @unique @map("file_path")
  fileType         String          @map("file_type")
  uploadedById     Int             @map("uploaded_by")
  createdAt        DateTime        @default(now()) @map("created_at")
  // ✅ 2. (Optional แนะนำให้มี) เพิ่มเวลาอัปเดต เพื่อให้รู้ว่าไฟล์ถูกกดลบ (isDeleted) ไปเมื่อไหร่
  updatedAt        DateTime        @updatedAt @map("updated_at")
  vehicleBookingId Int?            @map("vehicle_booking_id")
  roomBookingId    Int?            @map("room_booking_id")
  // ✅ 3. เพิ่ม onDelete: Cascade เพื่อให้ระบบเคลียร์ประวัติรูปรถยนต์ทิ้งอัตโนมัติ เมื่อใบจองรถถูกลบออกจากฐานข้อมูล
  bookingRoom      RoomBooking?    @relation(fields: [roomBookingId], references: [id], onDelete: Cascade)
  uploadedBy       User            @relation(fields: [uploadedById], references: [id]) // User ไม่ควรลบง่ายๆ จึงไม่ต้อง Cascade
  bookingVehicle   VehicleBooking? @relation(fields: [vehicleBookingId], references: [id], onDelete: Cascade)
  isDeleted        Boolean         @default(false) @map("is_deleted")

  @@index([vehicleBookingId])
  @@index([roomBookingId])
  @@index([uploadedById])
  // ✅ 4. เพิ่ม Compound Index เพื่อบูสต์ความเร็วการดึงรูปรถ/รูปห้อง ให้มีความเร็วระดับ O(1) (ค้นหาเจอทันทีไม่ต้องสแกนทั้งตาราง)
  @@index([entityType, entityId])
  @@map("attachments")
}

model RoomBookingHistory {
  id             Int         @id @default(autoincrement())
  roomBookingId  Int         @map("room_booking_id")
  changedById    Int         @map("changed_by_id")
  action         String
  statusSnapshot String      @map("status_snapshot")
  remark         String?
  createdAt      DateTime    @default(now()) @map("created_at")
  changedBy      User        @relation("RoomHistoryByUser", fields: [changedById], references: [id])
  roomBooking    RoomBooking @relation(fields: [roomBookingId], references: [id])

  @@index([roomBookingId])
  @@index([changedById])
  @@map("room_booking_histories")
}

model VehicleBookingHistory {
  id               Int            @id @default(autoincrement())
  vehicleBookingId Int            @map("vehicle_booking_id")
  changedById      Int            @map("changed_by_id")
  action           String
  statusSnapshot   String         @map("status_snapshot")
  remark           String?
  createdAt        DateTime       @default(now()) @map("created_at")
  changedBy        User           @relation("VehicleHistoryByUser", fields: [changedById], references: [id])
  vehicleBooking   VehicleBooking @relation(fields: [vehicleBookingId], references: [id])

  @@index([vehicleBookingId])
  @@index([changedById])
  @@map("vehicle_booking_histories")
}

enum RoomStatus {
  AVAILABLE
  IN_USE    @map("IN USE")
  RESERVED
}

enum VehicleStatus {
  AVAILABLE
  IN_USE    @map("IN USE")
  RESERVED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}
