// 1. บอกให้ระบบรู้ว่าจะสร้างเครื่องมือเชื่อมต่อกับ Node.js
generator client {
  provider = "prisma-client-js"
}

// 2. บอกให้ระบบรู้ว่าฐานข้อมูลเราคือ PostgreSQL และดึงรหัสผ่านจากไฟล์ .env
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 👑 ตารางสิทธิ์ผู้ใช้งาน (Role)
model Role {
  id        Int         @id @default(autoincrement())
  name      String      @unique // ตัวอย่างข้อมูล: "ADMIN", "USER", "GUARD"
  users     User[]
  pinAccess PinAccess[]

  @@map("roles")
}

// 👤 ตารางเก็บข้อมูลพนักงาน/ผู้ใช้งาน
model User {
  id              Int              @id @default(autoincrement())
  email           String?          @unique
  password        String?          // ให้เป็นค่าว่างได้สำหรับ User ธรรมดาที่ล็อกอินผ่านรหัสพนักงานอย่างเดียว
  
  employeeId      String?          @unique
  firstName       String?
  lastName        String?
  position        String?
  department      String?
  division        String?
  
  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id])
  roomBookings    RoomBooking[]
  vehicleBookings VehicleBooking[]
  
  @@map("users")
}

// 🏢 ตารางเก็บข้อมูลห้องประชุม
model Room {
  id           Int           @id @default(autoincrement())
  name         String        // ชื่อห้อง
  description  String?       // รายละเอียด
  capacity     Int?          // จำนวนคนที่รองรับได้
  isAvailable  Boolean       @default(true) // สถานะเปิดให้จองไหม
  roomBookings RoomBooking[] // ความสัมพันธ์: 1 ห้อง ถูกจองได้หลายรอบ
  createdAt    DateTime      @default(now())

  @@map("rooms")
}

// 📅 ตารางเก็บประวัติการจองคิวห้องประชุม
model RoomBooking {
  id        Int       @id @default(autoincrement())
  startTime DateTime  @map("start_time")
  endTime   DateTime  @map("end_time")
  status    String    @default("PENDING") // PENDING, APPROVED, CANCELLED
  userId    Int       @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  roomId    Int       @map("room_id")
  room      Room      @relation(fields: [roomId], references: [id])
  createdAt DateTime  @default(now()) @map("created_at")
  roomLogs  RoomLog[]

  @@map("room_bookings")
}

// 🚗 ตารางเก็บข้อมูลยานพาหนะ (อัปเดตแก้สายความสัมพันธ์เรียบร้อยแล้ว)
model Vehicle {
  id          Int              @id @default(autoincrement()) // ลำดับ (รันตัวเลขให้อัตโนมัติ)
  brand       String           // ยี่ห้อ (เช่น Toyota, Honda)
  model       String           // รุ่น (เช่น Camry, Civic)
  type        String           // ประเภทรถ (เช่น รถเก๋ง, รถตู้)
  plateNumber String           // ทะเบียนรถ (เช่น กข-1234)
  province    String           // จังหวัด (เช่น กรุงเทพมหานคร)
  color       String           // สี (เช่น ขาว, ดำ)
  imageUrl    String?          // รูปรถ (เก็บเป็นลิงก์ URL)
  
  // 🔗 เชื่อมโยงกลับไปยังตารางการจองรถ (Prisma บังคับให้ใส่ให้ครบสองฝั่ง)
  vehicleBookings VehicleBooking[]

  @@map("vehicles")
}

// 📅 ตารางเก็บประวัติการจองคิวรถยนต์
model VehicleBooking {
  id           Int          @id @default(autoincrement())
  startTime    DateTime     @map("start_time")
  endTime      DateTime     @map("end_time")
  status       String       @default("PENDING")
  startMileage Int?         @map("start_mileage") // รปภ. จดเลขไมล์ตอนออก
  endMileage   Int?         @map("end_mileage")   // รปภ. จดเลขไมล์ตอนคืน
  userId       Int          @map("user_id")
  user         User         @relation(fields: [userId], references: [id])
  vehicleId    Int          @map("vehicle_id")
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id])
  createdAt    DateTime     @default(now()) @map("created_at")
  vehicleLogs  VehicleLog[]
  attachments  Attachment[]

  @@map("vehicle_bookings")
}

// 📝 ตารางเก็บประวัติล็อกของห้องประชุม
model RoomLog {
  id        Int         @id @default(autoincrement())
  bookingId Int         @map("booking_id")
  booking   RoomBooking @relation(fields: [bookingId], references: [id])
  action    String      // เช่น "CHECKIN", "CHECKOUT"
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("room_logs")
}

// 📝 ตารางเก็บประวัติล็อกของรถยนต์
model VehicleLog {
  id        Int            @id @default(autoincrement())
  bookingId Int            @map("booking_id")
  booking   VehicleBooking @relation(fields: [bookingId], references: [id])
  action    String         // เช่น "DRIVE_OUT", "RETURNED"
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("vehicle_logs")
}

// 📎 ตารางเก็บไฟล์แนบ (เช่น รูปถ่ายรอยแผลรอบรถก่อนขับออก)
model Attachment {
  id        Int            @id @default(autoincrement())
  bookingId Int            @map("booking_id")
  booking   VehicleBooking @relation(fields: [bookingId], references: [id])
  url       String         // ที่อยู่ลิงก์รูปภาพ
  createdAt DateTime       @default(now()) @map("created_at")

  @@map("attachments")
}

// 🔑 ตารางรหัสผ่านเข้าควบคุมระบบ (PIN สำหรับ ADMIN / GUARD)
model PinAccess {
  id        Int      @id @default(autoincrement())
  roleId    Int      @map("role_id")
  role      Role     @relation(fields: [roleId], references: [id])
  pinCode   String   @map("pin_code")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pin_access")
}