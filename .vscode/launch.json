{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter Web",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/mobile_app",
            "program": "lib/main.dart"
        },
        {
            "name": "Flutter Profile",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/mobile_app",
            "program": "lib/main.dart",
            "flutterMode": "profile"
        },
        {
            "name": "Flutter Release",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/mobile_app",
            "program": "lib/main.dart",
            "flutterMode": "release"
        }
    ]
}